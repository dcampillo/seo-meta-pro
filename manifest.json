{
  "manifest_version": 3,
  "name": "SEO Meta Inspector",
  "version": "1.0.6",
  "description": "Extract and inspect title, description, and meta tags grouped by type.",
  "author": "David Campillo",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SEO Meta Inspector"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
